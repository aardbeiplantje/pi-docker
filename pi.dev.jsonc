{
  "$schema": "https://pi.dev/config.json",
  "provider": {
    "llama.cpp": {
      "type": "openai",
      "name": "llama-server (local)",
      "apiKey": "{env:LLAMA_SERVER_API_KEY}",
      "baseURL": "{env:LLAMA_SERVER_URL}"
    }
  },
  "model": "llama.cpp/{env:LLAMA_MODEL}",
  "tools": {
    "read": "allow",
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "grep": "deny",
    "find": "deny",
    "ls": "deny"
  },
  "stopSequences": ["\n\n"],
  "temperature": 0.1,
  "systemPrompt": "You are an expert software engineer. You must communicate exclusively in English. All tool execution variables, script paths, filenames, and reasoning strings MUST be written using standard alphanumeric English characters."
}
