{
  "additionalInclude": [
    "**/*.m"
  ],
  "exclude": [
    "**/node_modules**",
    "**/.git/**",
    "**~",
    "**.sw~"
  ],
  "embeddingProvider": "custom",
  "scope": "project",
  "customProvider": {
    "baseUrl": "{env:LLAMA_SERVER_URL}",
    "apiKey": "{env:LLAMA_SERVER_API_KEY}",
    "dimensions": 768,
    "maxTokens": 8192,
    "timeoutMs": 30000,
    "maxBatchSize": 512,
    "concurrency": 16,
    "model": "{env:INDEX_MODEL}"
  },
  "indexing": {
    "autoIndex": false,
    "requireProjectMarker": false,
    "autoGc": true
  },
  "debug": {
    "enabled": true,
    "metrics": true,
    "logLevel": "info"
  }
}
