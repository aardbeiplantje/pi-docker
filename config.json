{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "apiKey": "{env:LLAMA_SERVER_API_KEY}",
        "baseURL": "{env:LLAMA_SERVER_URL}"
      },
      "models": {
        "{env:LLAMA_MODEL}": {
          "name": "{env:LLAMA_MODEL}",
          "constraints": {
              "jsonMode": true
          },
          "parameters": {
            "stop": ["<|im_end|>", "<|object_ref_start|>"],
            "temperature": 0.1
          },
          "extraArgs": {
            "system_prompt_prefix": "You are an expert software engineer. You must communicate exclusively in English. All tool execution variables, script paths, filenames, and reasoning strings MUST be written using standard alphanumeric English characters."
          }
        }
      }
    }
  },
  "model": "llama.cpp/{env:LLAMA_MODEL}",
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  "plugin": [
    "opencode-codebase-index"
  ],
  "compaction": {
    "auto": true,
    "threshold": 0.75,
    "strategy": "summarize",
    "preserveRecentMessages": 6,
    "preserveSystemPrompt": true
  },
  "mcp": {
    "cocoindex-code": {
      "type": "local",
      "enabled": true,
      "command": ["ccc", "mcp"]
    }
  }
}
